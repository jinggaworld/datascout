# AI Backend: "groq" or "proxy" (ds2api)
AI_BACKEND=proxy

# DS2API Proxy (used when AI_BACKEND=proxy)
# ds2api runs on localhost:5001 by default
PROXY_BASE_URL=http://127.0.0.1:5001
PROXY_API_KEY=your-ds2api-key
PROXY_MODEL_PRIMARY=deepseek-v4-flash
PROXY_MODEL_FALLBACK=deepseek-v4-flash-nothinking

# Groq AI (used when AI_BACKEND=groq)
GROQ_API_KEY=gsk_xxxxxxxxxxxxx
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# CAP Protocol (Required for production)
CAP_AGENT_ID=datascout-agent-001
CAP_AGENT_WALLET=0x...

# Kaggle (Optional - get from kaggle.com/settings)
KAGGLE_USERNAME=
KAGGLE_KEY=

# FRED (Optional - get from fred.stlouisfed.org)
FRED_API_KEY=

# NOAA (Optional - get from ncdc.noaa.gov)
NOAA_API_KEY=

# CORE (Optional - get from core.ac.uk)
CORE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
