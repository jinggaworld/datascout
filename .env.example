# =============================================================================
# DataScout — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# Required: At least one AI backend key (GROQ_API_KEY or PROXY_API_KEY)
# Optional: API keys for additional data source adapters
# =============================================================================

# -----------------------------------------------------------------------------
# 1. AI Backend — Query Parser (REQUIRED: set at least one)
# -----------------------------------------------------------------------------
# Choose which AI backend to use for natural language query parsing.
# Options: "groq" (free, fast) or "proxy" (DeepSeek V4 Flash via ds2api)
AI_BACKEND=groq

# --- Option A: Groq API (recommended, free tier) ---
# Get your key at: https://console.groq.com
# Primary model: llama-3.3-70b-versatile
# Fallback model: llama-3.1-8b-instant
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# --- Option B: ds2api Proxy (DeepSeek V4 Flash) ---
# Requires running ds2api server at the specified URL.
# See: https://github.com/nicepkg/ds2api
# PROXY_BASE_URL=http://127.0.0.1:5001
# PROXY_API_KEY=
# PROXY_MODEL_PRIMARY=deepseek-v4-flash
# PROXY_MODEL_FALLBACK=deepseek-v4-flash-nothinking

# -----------------------------------------------------------------------------
# 2. CAP Protocol — CROO Agent Store Integration
# -----------------------------------------------------------------------------
# Required for registering as a paid agent on the CROO Network.
# Get credentials from: https://croo.network
CAP_API_URL=https://api.croo.network
CAP_WS_URL=wss://api.croo.network/ws
CAP_AGENT_ID=
CAP_AGENT_WALLET=

# -----------------------------------------------------------------------------
# 3. Data Source API Keys (all optional)
# -----------------------------------------------------------------------------
# These adapters work WITHOUT keys (public APIs):
#   ✅ HuggingFace Datasets Hub
#   ✅ OpenML
#   ✅ Zenodo
#   ✅ data.gov (Socrata)
#   ✅ World Bank Open Data
#   ✅ OpenAQ (air quality)
#   ✅ arXiv (academic papers)
#
# Add keys below to unlock additional sources:

# Kaggle — https://www.kaggle.com/settings (create API token)
KAGGLE_USERNAME=
KAGGLE_KEY=

# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NOAA Climate Data — https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_KEY=

# CORE (academic papers) — https://core.ac.uk/services/api
CORE_API_KEY=

# -----------------------------------------------------------------------------
# 4. Database / Cache
# -----------------------------------------------------------------------------
# SQLite database path for caching search results
DB_PATH=datascout.db

# -----------------------------------------------------------------------------
# 5. Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Rate limits
MAX_CONCURRENT_SEARCHES=10
REQUEST_TIMEOUT=30
