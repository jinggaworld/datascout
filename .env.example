# =============================================================================
# DataScout — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# Required: At least one AI backend key (OPENROUTER_API_KEY or GROQ_API_KEY)
# Optional: API keys for additional data source adapters
# =============================================================================

# -----------------------------------------------------------------------------
# 1. AI Backend — Query Parser (REQUIRED: set at least one)
# -----------------------------------------------------------------------------
# Choose which AI backend to use for natural language query parsing.
# Options: "openrouter" (default, Gemini models) or "groq" (free tier)
AI_BACKEND=openrouter

# --- Option A: OpenRouter (default, recommended) ---
# Get your key at: https://openrouter.ai/keys
# Primary model: google/gemini-2.5-flash-lite ($0.10/$0.40 per 1M tokens, 1M context)
# Fallback model: google/gemini-2.5-flash ($0.30/$2.50 per 1M tokens, 1M+ context)
OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRIMARY=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_FALLBACK=google/gemini-2.5-flash

# --- Option B: Groq API (free tier) ---
# Get your key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# 2. CAP Protocol — CROO Network (Production mode)
# -----------------------------------------------------------------------------
# Your agent identity on the CROO Agent Store.
# Register at: https://agentstore.croo.network
CAP_AGENT_ID=
CAP_AGENT_WALLET=
CAP_SDK_KEY=
CAP_PRIVATE_KEY=

# CROO API endpoints (defaults work for most setups)
CAP_API_URL=https://api.croo.network
CAP_WS_URL=wss://api.croo.network/ws

# Set to false to run without auto-connecting to CROO on startup
CAP_AUTO_CONNECT=true

# -----------------------------------------------------------------------------
# 3. Data Source API Keys (all optional — skip to use public APIs only)
# -----------------------------------------------------------------------------
# Kaggle — https://www.kaggle.com/settings (free)
KAGGLE_USERNAME=
KAGGLE_KEY=

# FRED (Federal Reserve) — https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=

# NOAA Climate — https://www.ncdc.noaa.gov/cdo-web/token (free)
NOAA_API_KEY=

# CORE Academic — https://core.ac.uk/services/api (free)
CORE_API_KEY=

# -----------------------------------------------------------------------------
# 4. Public APIs — No keys needed
# -----------------------------------------------------------------------------
# HuggingFace, OpenML, Zenodo, data.gov, World Bank, OpenAQ, arXiv
# These adapters work without any configuration.

# -----------------------------------------------------------------------------
# 5. Server Config
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Rate Limits
MAX_CONCURRENT_SEARCHES=10
REQUEST_TIMEOUT=30
